# ============================================================
# quantinvest 环境变量配置（教学版）
# 用法：复制本文件为 .env 并填入真实值。.env 不要提交到 Git。
# ============================================================

# 【必填】tushare 接口令牌。
# 申请：注册 https://tushare.pro → 个人中心 → 接口 TOKEN 复制。
# 没有它无法下载行情数据。
TUSHARE_TOKEN=

# 容器内数据路径（compose 已映射好，保持默认即可）
QLIB_DATA_PATH=/app/qlib_data/cn_data
PARQUET_DIR=/app/qlib_data/csv_tmp/tushare_daily
STOCK_META_DB=/app/data/stock_meta.db

# Flask 服务端口（容器内）
PORT=5055
HOST=0.0.0.0
# 本机访问端口映射。默认只监听本机回环，浏览器访问 http://127.0.0.1:5055
QI_PUBLISH_HOST=127.0.0.1
QI_PUBLISH_PORT=5055

# 【必填】Flask 会话密钥。生成命令（每个值都要独立生成，不要照抄）：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# 本地 HTTP 访问时设为 0；有 HTTPS 反代时设 1
QI_COOKIE_SECURE=0
QI_TRUST_PROXY=1
QI_TERMS_VERSION=2026-07-11

# 会员访问控制。学习用途建议保持 0（免登录，直接体验全部功能）。
# 设 1 则启用登录，角色/套餐见 README「会员体系」一节。
QI_AUTH_ENABLED=0
# 免登录模式下的身份：member/operator/admin；套餐：basic/data_pro/enterprise
QI_DEV_ROLE=admin
QI_DEV_PLAN=enterprise
QI_MEMBERS_DB=/app/data/members.db
# 启用登录时的管理员账号（QI_AUTH_ENABLED=1 才需要）
QI_ADMIN_EMAIL=
# 使用独立随机初始密码，首次登录后请修改
QI_ADMIN_PASSWORD=

# 运营主体公示信息。本地学习全部留空即可；
# 若要公网上线才需要填写并核对（合规要求）。
QI_OPERATOR_NAME=
QI_OPERATOR_LICENSE_NO=
QI_CONTACT_EMAIL=
QI_CONTACT_PHONE=
QI_ICP_NO=

# 每日自动更新时间（24 小时制，默认 21:00，A 股收盘后）
DAILY_UPDATE_HOUR=21
DAILY_UPDATE_MINUTE=0
# 更新失败后的当晚重试策略（一般不用改）
QI_DAILY_UPDATE_STATUS=/app/data/daily_update_status.json
QI_DAILY_UPDATE_MAX_RETRIES=2
QI_DAILY_UPDATE_RETRY_BASE_MINUTES=15
QI_DAILY_UPDATE_RETRY_CUTOFF_HOUR=23
QI_DAILY_UPDATE_STALE_HOURS=36

# 每隔几天刷新一次股票基础信息（行业/新股）
STOCK_META_REFRESH_DAYS=7
